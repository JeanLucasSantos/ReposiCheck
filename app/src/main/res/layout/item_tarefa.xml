<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/branco">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_toStartOf="@id/containerBadge"
                android:layout_alignParentStart="true">

                <TextView
                    android:id="@+id/txtNomeProduto"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nome do Produto"
                    android:textColor="@color/azul_escuro"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Estoque Baixo"
                    android:textColor="@color/vermelho_alerta"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginTop="2dp"/>

                <TextView
                    android:id="@+id/txtStatusEstoque"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Na Gôndola: 0 / Max: 0"
                    android:textColor="@color/cinza_texto"
                    android:textSize="13sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/containerBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="@android:color/holo_red_light"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:backgroundTint="@color/vermelho_alerta">

                <TextView
                    android:id="@+id/txtBadgeQtd"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Crítico"
                    android:textColor="@color/branco"
                    android:textSize="12sp"
                    android:textStyle="bold"/>
            </LinearLayout>

        </RelativeLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E4E7EC"
            android:layout_marginVertical="12dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end">

            <Button
                android:id="@+id/btnGondolaCheia"
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Gôndola Cheia"
                android:textColor="@color/verde_destaque"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btnRepor"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Repor"
                android:backgroundTint="@color/azul_escuro"
                android:textColor="@color/branco"
                android:textSize="14sp"
                app:cornerRadius="8dp" />
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>